# Firebase hosting
.firebase/*

# ==============================================================================
# Secrets & local config — NEVER commit these.
# Copy the corresponding *.example file and fill in your own values / assets.
# ==============================================================================

# Firebase app configs (contain project-specific API keys; provide your own)
android/app/google-services.json
android/app/src/dev/google-services.json
android/app/src/prod/google-services.json
ios/Runner/GoogleService-Info.plist
ios/flavors/dev/GoogleService-Info.plist
ios/flavors/prod/GoogleService-Info.plist
macos/Runner/GoogleService-Info.plist

# Android signing (release keystore + credentials). test.keystore is the
# public debug keystore (password "123456", Android/Flutter's own default) —
# it is not a secret and is committed on purpose; the debug build config and
# CI both need it.
android/keystore/*.jks
android/keystore/*.keystore
!android/keystore/test.keystore
android/keystore/key.properties
**/*.jks
**/*.keystore
!**/test.keystore

# Charles / mitmproxy debug SSL certificates (developer-local, do not ship)
assets/cert/*.pem

# Env files
*.env
.env*
!.env.example
ios/Flutter/ephemeral/

# Claude Code — agent tooling & instructions, not part of the project
CLAUDE.md
.claude/

# Internal backend handoff notes — not for the public repo (kept locally)
doc/backend-handoff.md
doc/backend-integration-checklist.md
mockoon/_bodies.json

# Local scratch & planning notes — not part of the project
tmp/
docs/design-specs/
