# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
# `**/doc/api/` игнорит dartdoc-артефакты, но у нас там лежит исходная
# OpenAPI-схема для swagger-генератора — её нужно коммитить (иначе CI не
# сгенерит API-клиент). Игнорим папку, но НЕ схему.
**/doc/api/
!doc/api/
!doc/api/openapi.json
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
.fvm/

# Web related

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
android/local.properties

.fvm/flutter_sdk
.fvm/fvm_config.json

