{
  "dart.flutterSdkPath": ".fvm/versions/3.44.0",
  "search.exclude": {
    "**/.fvm": true
  },
  "files.watcherExclude": {
    "**/.fvm": true
  },
  "actionButtons": {
    "reloadButton": null,
    "defaultColor": "white",
    "useScripts": true,
    "npmClient": "npm",
    "monorepo": true,
    "commands": [
      {
        "name": "🔨 gen",
        "color": "#ffffff",
        "command": "fvm flutter pub run build_runner build --delete-conflicting-outputs",
        "singleInstance": true
      },
      {
        "name": "👁️ gen",
        "color": "#ffffff",
        "command": "fvm flutter pub run build_runner watch --delete-conflicting-outputs",
        "singleInstance": true
      },
      {
        "name": "format",
        "color": "#ffffff",
        "command": "fvm flutter format -l 100 .",
        "singleInstance": true
      }
    ]
  },
  "yaml.schemas": {
    "https://json.schemastore.org/dart-build.json": [
      "build.yaml"
    ]
  },
  "liveServer.settings.root": "/build/web"
}