# Without this file, `docker build` sends the entire repo (build/, .dart_tool/,
# .git/, platform build dirs, IDE metadata) as build context, ballooning
# context size to gigabytes and upload/build time. Only the app source
# actually consumed by `flutter pub get` / `flutter build web` needs to reach
# the daemon.

.git/
.github/

# Build outputs (regenerated by the RUN steps in Dockerfile)
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# FVM (SDK is provided by the base image, not the host's .fvm/)
.fvm/

# Platform projects not built by this image
android/
ios/
macos/
linux/
windows/

# Tests, docs, tooling — irrelevant to the runtime image
test/
integration_test/
doc/
docs/
script/
*.md

# Editor/OS metadata
.idea/
.vscode/
.DS_Store
