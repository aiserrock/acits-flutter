openapi: 3.0.3
info:
  title: Acits API
  version: 1.0.0
  description: Animal shelter manager
paths:
  /api/schema/:
    get:
      operationId: schema_retrieve
      description: |-
        OpenApi3 schema for this API. Format can be selected via content negotiation.

        - YAML: application/vnd.oai.openapi
        - JSON: application/vnd.oai.openapi+json
      parameters:
      - in: query
        name: format
        schema:
          type: string
          enum:
          - json
          - yaml
      - in: query
        name: lang
        schema:
          type: string
          enum:
          - en
          - ru
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Schema
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/vnd.oai.openapi:
              schema:
                type: object
                additionalProperties: {}
            application/yaml:
              schema:
                type: object
                additionalProperties: {}
            application/vnd.oai.openapi+json:
              schema:
                type: object
                additionalProperties: {}
            application/json:
              schema:
                type: object
                additionalProperties: {}
          description: ''
  /api/token/:
    post:
      operationId: token_create
      description: |-
        Takes a set of user credentials and returns an access and refresh JSON web
        token pair to prove the authentication of those credentials.
      parameters:
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Token
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenObtainPair'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenObtainPair'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenObtainPair'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenObtainPair'
          description: ''
  /api/token/refresh/:
    post:
      operationId: token_refresh_create
      description: |-
        Takes a refresh type JSON web token and returns an access type JSON web
        token if the refresh token is valid.
      parameters:
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Token
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/v1/animals/:
    get:
      operationId: v1_animals_list
      parameters:
      - name: limit
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - name: offset
        required: false
        in: query
        description: The initial index from which to return the results.
        schema:
          type: integer
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: spec_category_name
        schema:
          type: string
        description: Species category name
      - in: query
        name: spec_name
        schema:
          type: string
        description: Species name
      - in: query
        name: spec_parent_name
        schema:
          type: string
        description: Species parent name
      - in: query
        name: status
        schema:
          type: array
          items:
            type: string
            enum:
            - ATTACHED
            - DEATH
            - EUTHANASIA
            - HOSPITAL
            - IN_THE_SHELTER
            - OVEREXPOSURE
            - PREPARING_TO_RELEASE
            - RELEASED
        explode: true
        style: form
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAnimalList'
          description: ''
    post:
      operationId: v1_animals_create
      parameters:
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Animal'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Animal'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Animal'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Animal'
          description: ''
  /api/v1/animals/{id}/:
    get:
      operationId: v1_animals_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Animal.
        required: true
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Animal'
          description: ''
    put:
      operationId: v1_animals_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Animal.
        required: true
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Animal'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Animal'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Animal'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Animal'
          description: ''
    patch:
      operationId: v1_animals_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Animal.
        required: true
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedAnimal'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedAnimal'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedAnimal'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Animal'
          description: ''
    delete:
      operationId: v1_animals_destroy
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Animal.
        required: true
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/v1/animals/{id}/{pdf_type}/pdf/:
    get:
      operationId: v1_animals_pdf_retrieve
      description: Generate PDF File by Animal, AnimalHistorySnapshot and Prescriptions.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      - in: path
        name: pdf_type
        schema:
          type: string
        description: One of ('history', 'history-editing', 'history-prescriptions')
        required: true
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/pdf:
              schema:
                type: string
                format: binary
          description: ''
  /api/v1/animals/{id}/files/:
    get:
      operationId: v1_animals_files_list
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Файл заявителя.
        required: true
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/ApplicantFile'
          description: ''
  /api/v1/animals/{id}/history/:
    get:
      operationId: v1_animals_history_list
      description: List of Animal History Snapshot.
      parameters:
      - in: query
        name: created_at_after
        schema:
          type: string
          format: date
        description: Date range from - to
      - in: query
        name: created_at_before
        schema:
          type: string
          format: date
        description: Date range from - to
      - in: query
        name: created_at_range
        schema:
          type: string
          format: date-time
          enum:
          - month
          - today
          - week
          - year
          - yesterday
        description: Date range
      - in: path
        name: id
        schema:
          type: integer
        required: true
      - name: limit
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - name: offset
        required: false
        in: query
        description: The initial index from which to return the results.
        schema:
          type: integer
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAnimalHistorySnapshotList'
          description: ''
  /api/v1/animals/{id}/prescriptions/:
    get:
      operationId: v1_animals_prescriptions_list
