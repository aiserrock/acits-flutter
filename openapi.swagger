      operationId: v1_users_available_workers_list
      description: List of available workers for the shelter.
      parameters:
      - name: limit
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - name: offset
        required: false
        in: query
        description: The initial index from which to return the results.
        schema:
          type: integer
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Users
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedUserShortSerializersList'
          description: ''
  /api/v1/users/me/:
    get:
      operationId: v1_users_me_retrieve
      description: User profile.
      parameters:
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Users
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserSerializers'
          description: ''
    put:
      operationId: v1_users_me_update
      description: User profile.
      parameters:
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Users
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UserSerializers'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/UserSerializers'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/UserSerializers'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserSerializers'
          description: ''
    patch:
      operationId: v1_users_me_partial_update
      description: User profile.
      parameters:
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Users
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedUserSerializers'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedUserSerializers'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedUserSerializers'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserSerializers'
          description: ''
  /api/v1/users/me/change_password/:
    put:
      operationId: v1_users_me_change_password_update
      description: Change password.
      parameters:
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Users
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UserChangePasswordSerializers'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/UserChangePasswordSerializers'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/UserChangePasswordSerializers'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserChangePasswordSerializers'
          description: ''
    patch:
      operationId: v1_users_me_change_password_partial_update
      description: Change password.
      parameters:
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Users
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedUserChangePasswordSerializers'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedUserChangePasswordSerializers'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedUserChangePasswordSerializers'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserChangePasswordSerializers'
          description: ''
  /api/v1/users/me/shelters/:
    get:
      operationId: v1_users_me_shelters_list
      description: List of user shelters.
      parameters:
      - name: limit
        required: false
        in: query
        description: Number of results to return per page.
        schema:
