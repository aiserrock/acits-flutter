            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAnimalNoteList'
          description: ''
    post:
      operationId: v1_animals_notes_create
      parameters:
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
