        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Applicant'
          description: ''
  /api/v1/applicants/{id}/:
    get:
      operationId: v1_applicants_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Заявитель.
        required: true
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Applicants
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Applicant'
          description: ''
    put:
      operationId: v1_applicants_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Заявитель.
        required: true
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Applicants
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Applicant'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Applicant'
