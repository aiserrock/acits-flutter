        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Species'
          description: ''
  /api/v1/animals/species/{id}/:
    get:
      operationId: v1_animals_species_retrieve
      description: A viewset that provides default `create()`, `retrieve()` and `list()`
