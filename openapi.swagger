          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AnimalNote'
          description: ''
  /api/v1/animals/notes/{id}/:
    get:
      operationId: v1_animals_notes_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Animal Note.
        required: true
      - in: header
        name: x-current-shelter
        schema:
          type: integer
          default: 2
        description: Set current shelter id
      tags:
      - Animals
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
