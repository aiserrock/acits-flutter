components:
  schemas:
    Animal:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        url:
          type: string
          format: uri
          readOnly: true
        name:
          type: string
          maxLength: 255
        avatar:
          type: string
          format: uri
          nullable: true
        avatar_filename:
          type: string
          readOnly: true
        spec:
          allOf:
          - $ref: '#/components/schemas/Species'
          readOnly: true
        spec_id:
          type: integer
          writeOnly: true
        status:
          $ref: '#/components/schemas/Status131Enum'
        date_joined:
          type: string
          format: date-time
        birth_date:
          type: string
          format: date
          nullable: true
        death_date:
          type: string
          format: date
          nullable: true
        death_reason:
          type: string
          maxLength: 128
        place_of_catch:
          type: string
          maxLength: 255
        place_of_release:
          type: string
          maxLength: 255
        date_of_chipping:
          type: string
          format: date
          nullable: true
        chipping_code:
          type: string
          maxLength: 50
        height:
          type: string
          pattern: ^\d+[.,]?\d*$
          maxLength: 10
        weight:
          type: string
          pattern: ^\d+[.,]?\d*$
          maxLength: 10
        has_documents:
          type: boolean
          readOnly: true
        shelter:
          type: integer
        curator:
          allOf:
          - $ref: '#/components/schemas/Curator'
          readOnly: true
        curator_id:
          type: integer
          writeOnly: true
          nullable: true
        applicant:
          allOf:
          - $ref: '#/components/schemas/Applicant'
          readOnly: true
        applicant_id:
          type: integer
          writeOnly: true
          nullable: true
        animal_attributes:
          type: array
          items:
            $ref: '#/components/schemas/AnimalAttributeValue'
        deleted_at:
          type: string
          format: date-time
          nullable: true
          readOnly: true
      required:
      - animal_attributes
      - applicant
      - avatar_filename
      - curator
      - date_joined
      - deleted_at
      - has_documents
      - id
      - place_of_catch
      - shelter
      - spec
      - spec_id
      - url
    AnimalAttribute:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 50
        is_required:
          type: boolean
      required:
      - id
      - name
    AnimalAttributeValue:
      type: object
      properties:
        attr_id:
          type: integer
        name:
          type: string
        value:
          type: string
          maxLength: 255
        is_required:
          type: boolean
          readOnly: true
      required:
      - attr_id
      - is_required
      - name
      - value
    AnimalHistorySnapshot:
      type: object
      properties:
        animal:
          type: integer
        created_at:
          type: string
          format: date-time
          readOnly: true
        status:
          $ref: '#/components/schemas/Status131Enum'
        height:
          type: string
          maxLength: 10
        weight:
          type: string
          maxLength: 10
        shelter_name:
          type: string
        editor:
          type: string
      required:
      - animal
      - created_at
      - editor
      - shelter_name
    AnimalNote:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        url:
          type: string
          format: uri
          readOnly: true
        animal:
          type: integer
        content:
          type: string
        files:
          type: array
          items:
            $ref: '#/components/schemas/AnimalNoteFile'
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        created_by:
          type: string
          readOnly: true
        updated_by:
          type: string
          readOnly: true
        is_user_can_edit_or_delete:
          type: boolean
          readOnly: true
      required:
      - animal
      - content
      - created_at
      - created_by
      - id
      - is_user_can_edit_or_delete
      - updated_at
      - updated_by
      - url
    AnimalNoteFile:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        file:
          type: string
          format: uri
        name:
          type: string
          writeOnly: true
          maxLength: 255
        filename:
          type: string
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - file
      - filename
      - id
      - name
    AnimalPrescription:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        my_type:
          $ref: '#/components/schemas/MyTypeEnum'
        duration:
          $ref: '#/components/schemas/DurationEnum'
        description:
          type: string
          maxLength: 1024
        created_by:
          type: string
          readOnly: true
        updated_by:
          type: string
          readOnly: true
        drugs:
          type: array
          items:
            $ref: '#/components/schemas/PrescriptionDrug'
        executions:
          type: array
          items:
            $ref: '#/components/schemas/PrescriptionExecution'
      required:
      - created_by
      - drugs
      - executions
      - id
      - updated_by
    Applicant:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        url:
          type: string
          format: uri
          readOnly: true
        shelter:
          type: integer
          readOnly: true
        first_name:
          type: string
          maxLength: 50
        last_name:
          type: string
          maxLength: 150
        email:
          type: string
          format: email
          nullable: true
          maxLength: 254
        phone_number:
          type: string
          pattern: ^\+?1?\d{9,15}$
          maxLength: 17
        contact_details:
          type: string
          format: uri
          title: Social links
          maxLength: 200
        created_by:
          type: string
          readOnly: true
        updated_by:
          type: string
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        animal_id:
          type: integer
          writeOnly: true
        applicant_files:
          type: array
          items:
            $ref: '#/components/schemas/ApplicantFile'
      required:
      - created_at
      - created_by
      - first_name
      - id
      - last_name
      - phone_number
      - shelter
      - updated_at
      - updated_by
      - url
    ApplicantFile:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        file:
          type: string
          format: uri
        name:
          type: string
          writeOnly: true
          maxLength: 255
        filename:
          type: string
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - file
      - filename
      - id
      - name
    Approve:
      type: object
      properties:
        status:
          type: string
      required:
      - status
    Curator:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        url:
          type: string
          format: uri
          readOnly: true
        shelter:
          type: string
          readOnly: true
        first_name:
          type: string
          maxLength: 50
        last_name:
          type: string
          maxLength: 150
        email:
          type: string
          format: email
          maxLength: 254
        phone_number:
          type: string
          pattern: ^\+?1?\d{9,15}$
          maxLength: 17
        address:
          type: string
          maxLength: 255
      required:
      - email
      - first_name
      - id
      - last_name
      - phone_number
      - shelter
      - url
    Decline:
      type: object
      properties:
        status:
          type: string
      required:
      - status
    Drug:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 255
        usage_instruction:
          type: string
          maxLength: 1024
        form_of_drug:
          type: integer
        form_of_drug_name:
          type: string
          readOnly: true
      required:
      - form_of_drug
      - form_of_drug_name
      - id
      - name
      - usage_instruction
    DurationEnum:
      enum:
      - EVERYDAY
      - EVERY_WEEK
      - CUSTOM
      type: string
    Feedback:
      type: object
      properties:
        shelter_id:
          type: integer
        shelter_name:
          type: string
        date:
          type: string
          format: date
        action:
          type: string
        email:
          type: string
          format: email
        message:
          type: string
      required:
      - action
      - date
      - email
      - message
      - shelter_id
      - shelter_name
    LevelEnum:
      enum:
      - 1
      - 2
      - 3
      type: integer
    MyTypeEnum:
      enum:
      - COURSE_OF_TREATMENT
      - APPOINTMENT
      - READMISSION
      - REMOVING_STITCHES
      - WOUND_HEALING
      - ANALYSIS
      type: string
    PaginatedAnimalHistorySnapshotList:
      type: object
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=400&limit=100
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=200&limit=100
        results:
          type: array
          items:
            $ref: '#/components/schemas/AnimalHistorySnapshot'
    PaginatedAnimalList:
      type: object
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=400&limit=100
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=200&limit=100
        results:
          type: array
          items:
            $ref: '#/components/schemas/Animal'
